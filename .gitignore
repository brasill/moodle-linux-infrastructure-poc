# ==============================================================================
# .gitignore — Linux Infrastructure Projects
# Target: Linux / DevOps / Sysadmin repositories
# Host system: Gentoo
# Editor: VSCode
# ==============================================================================


# ==============================================================================
# 1. ARCHIVES AND BACKUPS
# ------------------------------------------------------------------------------
# Infrastructure work frequently produces compressed archives and system images.
# These files are large and should never be committed to Git.
# ==============================================================================

*.tar
*.tar.gz
*.tar.xz
*.tar.zst
*.zip
*.7z

*.bak
*.backup
*.old

*.img
*.iso


# ==============================================================================
# 2. KERNEL BUILD ARTIFACTS
# ------------------------------------------------------------------------------
# Prevent accidental commits if kernel builds are executed in or near the repo.
# Relevant for systems compiling kernels locally (e.g., Gentoo).
# ==============================================================================

.config
.config.old

Module.symvers
modules.order

*.o
*.ko
*.mod
*.mod.c

.built-in.a

vmlinux
System.map


# ==============================================================================
# 3. TEMPORARY EDITOR FILES
# ------------------------------------------------------------------------------
# Temporary files generated by CLI editors.
# ==============================================================================

*~
.*.sw[a-p]
.*.swo
\#*\#
DEADJOE


# ==============================================================================
# 4. SYSTEM LOGS AND RUNTIME OUTPUT
# ------------------------------------------------------------------------------
# Log files generated by services or scripts during testing.
# These should never be versioned.
# ==============================================================================

*.log
*.err
*.out

logs/
crash_notes/


# ==============================================================================
# 5. ENVIRONMENT AND SECRET FILES
# ------------------------------------------------------------------------------
# Prevent leaking credentials, API tokens, database passwords, etc.
# ==============================================================================

.env
.env.*
*.secret
*.secrets

*.pem
*.key


# ==============================================================================
# 6. EDITOR / IDE DIRECTORIES
# ------------------------------------------------------------------------------
# Editor-specific configuration directories that should not be shared.
# ==============================================================================

.vscode/
.idea/
*.sublime-workspace
*.sublime-project


# ==============================================================================
# 7. OS-SPECIFIC FILES
# ------------------------------------------------------------------------------
# Files created automatically by different operating systems.
# ==============================================================================

.DS_Store
Thumbs.db


# ==============================================================================
# 8. INFRASTRUCTURE AUTOMATION TOOLS (OPTIONAL FUTURE USE)
# ------------------------------------------------------------------------------
# These tools are common in DevOps environments. Including them prevents
# accidental commits if the repository evolves.
# ==============================================================================

# Terraform
.terraform/
terraform.tfstate*
*.tfvars

# Ansible
*.retry


# ==============================================================================
# END OF FILE
# ==============================================================================
